rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Password reset codes
    match /password_reset_codes/{email} {
      allow read, write: if true;
    }
    
    // Verification documents
    match /verifications/{verificationId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Properties
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if request.auth != null && (
        resource == null || 
        resource.data.landlordId == request.auth.uid || 
        isAdmin()
      );
    }

    // Support Chats
    match /support_chats/{chatId} {
      allow read, write: if request.auth != null && (request.auth.uid == chatId || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          (exists(/databases/$(database)/documents/support_chats/$(chatId)) && get(/databases/$(database)/documents/support_chats/$(chatId)).data.userId == request.auth.uid) || 
          isAdmin()
        );
      }
    }

    // Tour Requests
    match /tour_requests/{requestId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid || isAdmin());
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      
      match /items/{itemId} {
        allow read: if request.auth != null && (notificationId == request.auth.uid || isAdmin());
        // Allow any authenticated user to send a notification (write)
        allow write: if request.auth != null;
      }
    }

    // Reports
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    // Favorites
    match /favorites/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      match /properties/{propertyId} {
        allow read, write: if request.auth != null && (userId == request.auth.uid || isAdmin());
      }
    }

    // Peer-to-peer Messages (Chat)
    match /conversations/{conversationId} {
      // Allow read if user is authenticated and either doc doesn't exist (returns not found)
      // or user is in the participants array
      allow read: if request.auth != null && (
        resource == null || 
        request.auth.uid in resource.data.participants || 
        isAdmin()
      );
      
      // Allow write if user is creating a new conversation they belong to, or updating an existing one they belong to
      allow write: if request.auth != null && (
        (request.resource.data.participants != null && request.auth.uid in request.resource.data.participants) ||
        (resource != null && request.auth.uid in resource.data.participants) ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        // For messages, check the parent conversation's participants
        allow read, write: if request.auth != null && (
          (exists(/databases/$(database)/documents/conversations/$(conversationId)) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants) || 
          isAdmin()
        );
      }
    }
  }
}
