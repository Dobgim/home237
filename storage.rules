rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Property images - any authenticated user can upload, anyone can read
    match /properties/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Verification documents - only the owning user can upload/read
    match /verifications/{userId}/{fileName} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Profile images
    match /profiles/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
